{
  "name": "@hybridgym/framer-components",
  "version": "1.0.0",
  "description": "StrongX-inspired Framer components for Hybrid Gym fitness website",
  "main": "index.ts",
  "author": "Hybrid Gym",
  "license": "MIT",
  "framer": {
    "displayName": "Hybrid Gym Components",
    "components": [
      {
        "name": "HybridHero",
        "displayName": "Hero Section",
        "description": "Full-screen hero with animated headline, CTAs, and background image"
      },
      {
        "name": "HybridMarquee",
        "displayName": "Services Marquee",
        "description": "Infinite scrolling services banner"
      },
      {
        "name": "HybridServiceCard",
        "displayName": "Service Card",
        "description": "Service feature card with icon"
      },
      {
        "name": "HybridStatsCard",
